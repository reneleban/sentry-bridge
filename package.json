{
  "name": "obico-prusalink-bridge",
  "version": "0.1.0",
  "description": "Docker-based agent connecting Prusa Core One (PrusaLink) to Obico",
  "main": "dist/index.js",
  "scripts": {
    "install:all": "npm install && cd frontend && npm install",
    "dev:backend": "nodemon --exec ts-node src/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend:proxy": "cd frontend && npm run dev:proxy",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "start:backend": "node dist/index.js",
    "start:all": "npm run build:all && npm run start:backend",
    "test:backend": "jest",
    "test:all": "npm run test:backend",
    "typecheck": "tsc --noEmit",
    "build:docker": "docker build -t obico-prusalink-bridge .",
    "build:docker:multiplatform": "docker buildx build --platform linux/amd64,linux/arm64 -t obico-prusalink-bridge .",
    "prepare": "husky"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "digest-fetch": "^3.1.1",
    "express": "^4.19.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.5.2",
    "@types/supertest": "^6.0.2",
    "concurrently": "^8.2.2",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.2.7",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  }
}
