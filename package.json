{
  "name": "obico-prusalink-bridge",
  "version": "1.0.0",
  "description": "Docker-based agent connecting Prusa Core One (PrusaLink) to Obico",
  "main": "dist/index.js",
  "scripts": {
    "install:all": "npm install && cd frontend && npm install",
    "dev:backend": "CONFIG_PATH=./config/config.json nodemon --exec ts-node src/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend:proxy\"",
    "dev:frontend:proxy": "cd frontend && npm run dev:proxy",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "start:backend": "node dist/index.js",
    "start:all": "npm run build:all && npm run start:backend",
    "test:backend": "jest",
    "test:all": "npm run test:backend",
    "typecheck": "tsc --noEmit",
    "build:docker": "docker build -t obico-prusalink-bridge .",
    "build:docker:multiplatform": "docker buildx build --platform linux/amd64,linux/arm64 -t obico-prusalink-bridge .",
    "docker:dev": "docker compose up --build -d",
    "docker:run": "docker compose up --pull never -d",
    "docker:logs": "docker compose logs -f",
    "docker:clean": "docker compose down --rmi local; true",
    "prepare": "husky"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "digest-fetch": "^3.1.1",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "husky": "^9.0.11",
    "jest": "^30.3.0",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  }
}
