# Copy to .env for local development — these values are the defaults used in production.
# In Docker, override via environment: in docker-compose.yml or -e flags.

# === Server ===
PORT=3000
CONFIG_PATH=/config/config.json

# === Circuit Breaker (PrusaLink HTTP) ===
# Number of consecutive failures before opening the circuit
CIRCUIT_BREAKER_THRESHOLD=5
# Time (ms) to wait before attempting a test request (HALF_OPEN)
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000

# === Retry / Exponential Backoff ===
# Initial delay before first retry (ms)
RETRY_BASE_DELAY_MS=1000
# Maximum delay between retries (ms)
RETRY_MAX_DELAY_MS=30000

# === Health Check ===
# Time (ms) a critical component can stay DOWN before /api/health/ready returns 503
# Critical components: prusalink, camera, obico_ws
HEALTHCHECK_CRITICAL_TIMEOUT_MS=120000

# === Janus WebRTC ===
# Mode: bundled (bridge manages Janus binary) | hosted (external/sidecar) | auto
JANUS_MODE=bundled
# Log verbosity: 0=Fatal 1=Err 2=Warn 3=Info 4=Verbose 5=Huge
JANUS_DEBUG_LEVEL=2
# LAN IP of the machine running Docker. Janus advertises this as ICE candidate
# so the browser / Obico server can reach it for WebRTC. Required for WebRTC to work.
# Example: JANUS_HOST_IP=192.168.178.50
JANUS_HOST_IP=
